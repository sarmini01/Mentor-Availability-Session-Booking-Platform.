class AvailabilitySlot {
    private int slotId;
    private int mentorId;
    private String date;
    private String startTime;
    private String endTime;
    private boolean isBooked;
    public boolean checkAvailability() {
        return !isBooked;
    }
    public void markAsBooked() {
        isBooked = true;
    }
    public void markAsAvailable() {
        isBooked = false;
    }
}
